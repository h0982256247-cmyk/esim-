# ── Supabase 資料庫 ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase Storage（Logo 上傳用）───────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── LINE ─────────────────────────────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
NEXT_PUBLIC_LIFF_ID=

# ── TapPay 金流（伺服器端）───────────────────────────────────────
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_ENV=sandbox

# ── TapPay SDK（前端瀏覽器端）────────────────────────────────────
NEXT_PUBLIC_TAPPAY_APP_ID=
NEXT_PUBLIC_TAPPAY_APP_KEY=
NEXT_PUBLIC_TAPPAY_ENV=sandbox

# ── 平台後台 JWT ──────────────────────────────────────────────────
PLATFORM_JWT_SECRET=

# ── eSIM 供應商（世界移動）───────────────────────────────────────
ESIM_SUPPLIER_API_URL=https://fmshippingsys.fastmove.com.tw
ESIM_SUPPLIER_API_URL_TEST=https://tfmshippingsys.fastmove.com.tw
ESIM_MERCHANT_ID=
ESIM_DEPT_ID=
ESIM_TOKEN=

# ── Vercel Cron 共用密鑰 ──────────────────────────────────────────
# 用於驗證 /api/cron/* 由 Vercel 排程系統呼叫（非必填，但部署到 production 強烈建議設定）
CRON_SECRET=

# ── 欄位加密金鑰 ──────────────────────────────────────────────────
# 用於加密 TapPay token、世界移動 token、社群主銀行帳號等敏感欄位（AES-256-GCM）
# 必須為 64 字元 hex（32 bytes）。產生方式：`openssl rand -hex 32`
FIELD_ENCRYPTION_KEY=
