# ── Supabase 資料庫 ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase Storage（Logo 上傳用）───────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── 網站 Session 簽章（平台級，必填）─────────────────────────────
# 簽 esim_session（使用者登入 cookie）。這是「網站自己的」簽章金鑰，
# 與任何 LINE Login Channel Secret 無關，請用獨立隨機值：`openssl rand -hex 32`。
# 未設定時會退回舊的 LINE_CHANNEL_SECRET（向後相容，建議盡快改用本變數）。
SESSION_SECRET=

# ── LINE（多租戶：每個白牌在「後台 → LINE 設定」各自填）──────────
# 下列為「單租戶部署 / 本機開發」的 fallback；正式多白牌時改由各 tenant 後台設定：
#   - LIFF ID / Login Channel：存在 PlatformAdmin.liffId（前端依 slug 取該租戶 liffId）
#   - Messaging API 推播 token：存在 PlatformAdmin.lineAccessToken（加密），推播依訂單租戶解析
LINE_CHANNEL_ID=                 # 單租戶 fallback：驗 LIFF id token 的 channelId（多租戶時由 liffId 前綴解析）
LINE_CHANNEL_SECRET=             # 已棄用於 session 簽章；僅作 SESSION_SECRET 未設定時的相容 fallback
LINE_CHANNEL_ACCESS_TOKEN=       # 單租戶 fallback：推播 token（多租戶時用 PlatformAdmin.lineAccessToken）
NEXT_PUBLIC_LIFF_ID=             # 僅後台設定頁顯示 LIFF URL 用；前台不讀（前台依 slug 取租戶 liffId）

# ── TapPay 金流（伺服器端；多租戶時用後台 TenantPaymentConfig，下列僅 fallback）─
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_LINEPAY_MERCHANT_ID=      # 選填；LINE Pay 用的 merchantId，未設定時退回 TAPPAY_MERCHANT_ID
TAPPAY_ENV=sandbox

# ── TapPay SDK（前端瀏覽器端）────────────────────────────────────
NEXT_PUBLIC_TAPPAY_APP_ID=
NEXT_PUBLIC_TAPPAY_APP_KEY=
NEXT_PUBLIC_TAPPAY_ENV=sandbox

# ── 平台後台 JWT ──────────────────────────────────────────────────
PLATFORM_JWT_SECRET=

# ── eSIM 供應商（世界移動；多租戶時用後台 TenantEsimConfig，下列僅 fallback）──
ESIM_SUPPLIER_API_URL=https://fmshippingsys.fastmove.com.tw
ESIM_SUPPLIER_API_URL_TEST=https://tfmshippingsys.fastmove.com.tw
ESIM_MERCHANT_ID=
ESIM_DEPT_ID=
ESIM_TOKEN=

# ── Vercel Cron 共用密鑰 ──────────────────────────────────────────
# 用於驗證 /api/cron/* 由 Vercel 排程系統呼叫（非必填，但部署到 production 強烈建議設定）
CRON_SECRET=

# ── 欄位加密金鑰 ──────────────────────────────────────────────────
# 用於加密 TapPay token、世界移動 token、社群主銀行帳號等敏感欄位（AES-256-GCM）
# 必須為 64 字元 hex（32 bytes）。產生方式：`openssl rand -hex 32`
FIELD_ENCRYPTION_KEY=
